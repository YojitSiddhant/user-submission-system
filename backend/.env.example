PORT=5050
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Railway production example:
# FRONTEND_URL=https://your-vercel-domain.vercel.app

# Local development values
DB_HOST=localhost
DB_PORT=3306
DB_SOCKET=/tmp/mysql.sock
DB_USER=root
DB_PASSWORD=
DB_NAME=user_document_submissions

# Railway MySQL service values (use these on Railway if present)
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_BYTES=5242880
